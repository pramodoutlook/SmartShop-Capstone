{
  "name": "smartshop-lite",
  "version": "1.0.0",
  "description": "SmartShop Lite - lightweight eCommerce starter with Express, EJS, Jest, and GitHub Actions",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "build": "node -e \"console.log('No build step required for this runtime')\"",
    "test": "jest --runInBand --coverage",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "ecommerce",
    "express",
    "nodejs",
    "jest",
    "smartshop"
  ],
  "author": "SmartShop Lite",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/services/**/*.js",
      "src/models/**/*.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageDirectory": "coverage"
  }
}