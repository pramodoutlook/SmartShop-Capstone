<%- include("partials/header", { title: title, cartCount: cartCount }) %>

<section class="details">
  <div class="details-image">
    <img src="<%= product.imageUrl %>" alt="<%= product.name %>" />
  </div>
  <div class="details-content">
    <p class="category"><%= product.category %></p>
    <h1><%= product.name %></h1>
    <p><%= product.description %></p>
    <p class="price">$<%= product.price.toFixed(2) %></p>

    <form class="quantity-form" method="POST" action="/cart">
      <input type="hidden" name="productId" value="<%= product.id %>" />
      <label for="quantity">Quantity</label>
      <input id="quantity" name="quantity" type="number" min="1" max="99" value="1" />
      <button class="btn" type="submit">Add to Cart</button>
    </form>

    <p><a class="btn ghost" href="/">Back to Catalog</a></p>
  </div>
</section>

<%- include("partials/footer") %>